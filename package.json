{
  "name": "read-terms-for-me",
  "version": "0.2.0",
  "description": "Chrome extension that detects Terms of Service links and scores them with configurable privacy rules",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:zip": "bun run build && rm -f read-terms-for-me.zip && cd dist && zip -r ../read-terms-for-me.zip .",
    "build:watch": "vite build --watch",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "lucide-react": "^0.397.0",
    "react": "^18.3.1",
    "react-aria-components": "^1.2.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0-alpha.24",
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "tailwindcss": "^4.0.0-alpha.24",
    "typescript": "^5.4.5",
    "vite": "^5.3.2"
  }
}
